# Civitai API token (нужен для скачивания части моделей/LoRA и приватного контента)
# Получить: https://civitai.com/user/account -> API Keys
CIVITAI_API_TOKEN=

# RunPod Serverless
# https://www.runpod.io/console/serverless -> ваш endpoint
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Примечание: CIVITAI_TOKEN для скачивания моделей задаётся НЕ здесь,
# а в Environment Variables самого RunPod endpoint (см. worker/README.md).
# Приложению Next.js токен нужен только для поиска (CIVITAI_API_TOKEN выше).
